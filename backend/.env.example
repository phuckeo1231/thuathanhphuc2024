# Cổng HTTP server (WebSocket cũng chạy trên cổng này)
PORT=8080

# Loại provider: "ws" (realtime) hoặc "http" (polling)
PROVIDER_TYPE=http

# BSC Mainnet RPC (HTTP)
BSC_HTTP_URL=https://bsc-dataseed.binance.org

# Tối ưu tốc độ tải số dư khi PROVIDER_TYPE=bscscan
# Dùng RPC riêng trả phí sẽ ổn định hơn RPC public.
BSCSCAN_POLL_MS=120000
BSCSCAN_CONCURRENCY=10
BSCSCAN_STAGGER_MS=50

# BSC Mainnet RPC (WebSocket) — chỉ dùng khi PROVIDER_TYPE=ws
BSC_WS_URL=wss://bsc.publicnode.com

# Khoảng thời gian polling (ms) — chỉ dùng khi PROVIDER_TYPE=http
POLL_INTERVAL_MS=15000

# Cài đặt cảnh báo
ALERT_THRESHOLD_RAW=1000000000000000000   # 1 token (18 decimals)
ALERT_CHANGE_PERCENT=10                   # Cảnh báo khi thay đổi >= 10%

# ── Ví cần theo dõi ───────────────────────────────────────────
# Thêm bao nhiêu ví tuỳ ý: WALLET_1, WALLET_2, WALLET_3...
# Mỗi ví có thể đặt nhãn riêng bằng WALLET_N_LABEL (tuỳ chọn)
# Nếu để trống toàn bộ → dùng 8 ví mặc định (Binance, OKX, PancakeSwap...)

# Binance
WALLET_1=0xF977814e90dA44bFA03b6295A0616a897441aceC
WALLET_1_LABEL=Binance Hot Wallet 8

WALLET_2=0x21a31Ee1afC51d94C2eFcCAa2092aD1028285549
WALLET_2_LABEL=Binance Hot Wallet 15

WALLET_3=0x28C6c06298d514Db089934071355E5743bf21d60
WALLET_3_LABEL=Binance Hot Wallet 14

WALLET_4=0x5a52E96BAcdaBb82fd05763E25335261B270Efcb
WALLET_4_LABEL=Binance Treasury

# OKX
WALLET_5=0x5041ed759Dd4aFc3a72b8192C143F72f4724081F
WALLET_5_LABEL=OKX Hot Wallet

# PancakeSwap
WALLET_6=0x73feaa1eE314F8c655E354234017bE2193C9E24E
WALLET_6_LABEL=PancakeSwap MasterChef

# Ví cá voi
WALLET_7=0x8894e0a0c962cb723c1976a4421c95949be2d4e3
WALLET_7_LABEL=BSC Whale 1

WALLET_8=0xDEF171Fe48CF0115B1d80b88dc8eAB59176FEe57
WALLET_8_LABEL=ParaSwap BSC

# Thêm ví của bạn vào đây:
# WALLET_9=0xYourWalletAddress
# WALLET_9_LABEL=Ví của tôi

# ── Arkham Intelligence (tuỳ chọn) ────────────────────────────
# Chọn 1 trong 2 cách bên dưới. ARKHAM_COOKIE ưu tiên hơn.
#
# Cách 1: Session cookie từ trình duyệt (lấy từ trang intel.arkm.com)
#   1. Đăng nhập vào https://intel.arkm.com/
#   2. Mở DevTools (F12) → tab Network
#   3. Reload trang → click request bất kỳ đến intel.arkm.com
#   4. Request Headers → sao chép toàn bộ dòng Cookie: ...
#   5. Dán vào đây (bỏ chữ "Cookie: " ở đầu)
ARKHAM_COOKIE=

# Cách 2: API key chính thức (đăng ký tại https://info.arkm.com/api-platform)
ARKHAM_API_KEY=
